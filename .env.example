# aurantium — optional API keys. Easiest: File ▸ API Keys… inside the app.
# Or copy this file to `.env` (git-ignored) and fill in what you use.
# Every core panel works with NO keys (yfinance + gnews are keyless).

# FRED (Federal Reserve Economic Data) — free key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# EIA (U.S. Energy Information Administration) — free key: https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# NewsAPI.org — optional, upgrades the news panel's primary source
NEWSAPI_KEY=

# Finnhub — first-choice real-time quote source — free key: https://finnhub.io/register
FINNHUB_API_KEY=

# Twelve Data — second-choice quote source — free key: https://twelvedata.com/pricing
TWELVEDATA_API_KEY=
